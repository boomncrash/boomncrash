{
  "name": "bountly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix web",
    "build": "npm run build --prefix web",
    "start": "npm run start --prefix web",
    "lint": "npm run lint --prefix web",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:deploy:base-sepolia": "hardhat run scripts/deploy-base.ts --network baseSepolia",
    "contracts:deploy:base-mainnet": "hardhat run scripts/deploy-base.ts --network base",
    "contracts:deploy:solana-devnet": "anchor build && anchor deploy --provider.cluster devnet && npx ts-node scripts/write-solana-deployment.ts devnet",
    "contracts:deploy:solana-mainnet": "anchor build && anchor deploy --provider.cluster mainnet && npx ts-node scripts/write-solana-deployment.ts mainnet"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.14.5",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "dotenv": "^17.2.2",
    "ethers": "^6.17.0",
    "hardhat": "^2.22.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
