# boomncrash Web Environment

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Privy — email login + embedded wallets (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=

# Session auth (legacy custom auth — not needed with Privy)
# AUTH_SECRET=

# Base Sepolia (default) or mainnet
NEXT_PUBLIC_BASE_NETWORK=testnet
NEXT_PUBLIC_BASE_CHAIN_ID=84532
NEXT_PUBLIC_BASE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_BOUNTY_FACTORY_ADDRESS=

# Solana Devnet (default) or mainnet
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_SOLANA_PROGRAM_ID=

# Production mainnet example:
# NEXT_PUBLIC_BASE_NETWORK=mainnet
# NEXT_PUBLIC_BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# NEXT_PUBLIC_SOLANA_NETWORK=mainnet
# NEXT_PUBLIC_SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# On-ramp (NGN default on /wallet)
NEXT_PUBLIC_ONRAMPER_API_KEY=

# Session auth + encrypted embedded wallets (required in production)
AUTH_SECRET=

# Admin moderation (required in production)
ADMIN_SECRET=

# Email alerts via Resend (admin + optional user notifications from Dashboard)
RESEND_API_KEY=
ADMIN_ALERT_EMAIL=
EMAIL_FROM=boomncrash <onboarding@resend.dev>

# Rally milestone webhooks (optional — fires at 50% and 100% funding)
RALLY_WEBHOOK_URL=

# Database (auto-set on Netlify as NETLIFY_DB_URL)
# DATABASE_URL=
